#!/usr/bin/env bash
set -euo pipefail

# Resolve the project root (where libexec/ and modules/ live)
if ! command -v realpath >/dev/null 2>&1; then
	printf 'Error: "realpath" is required but not found\n' >&2
	exit 1
fi
GIT_HOOKD_ROOT="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"

# Where hooks get installed (user-overridable)
GIT_HOOKD_DIR="${GIT_HOOKD_DIR:-$HOME/.local/share/git-hookd}"
export GIT_HOOKD_DIR

VERSION="0.1.0"

usage() {
	cat <<EOF
git-hookd v${VERSION} - modular global git hooks

Usage: git hookd <command> [options]

Commands:
  install [--force] [--dry-run]     Set up hooks directory + core.hooksPath
  uninstall                         Remove git-hookd and restore previous config
  enable [--priority N] <module>    Enable a module (symlink into .d/ dir)
  disable <module>                  Disable a module (remove symlink)
  list                              Show available modules and their status
  status                            Show installation status

Options:
  -h, --help      Show this help
  -v, --version   Show version

Configuration (git config):
  hookd.skip <module>                   Skip a module in this repo
  hookd.protect-branch.pattern <glob>   Custom protected branch patterns
  hookd.auto-fetch.cooldown <seconds>   Fetch cooldown (default: 60)
  hookd.auto-fetch.remote <name>        Remote to fetch (default: origin)

  Use --global for all repos, or omit for per-repo config.
  Use --add for multiple values (e.g. multiple skip entries).
EOF
}

cmd="${1:-}"
shift || true

# Intercept --help/-h anywhere in args (e.g. "git hookd install --help")
for arg in "$@"; do
	case "$arg" in
		--help | -h)
			usage
			exit 0
			;;
	esac
done

case "$cmd" in
	install | uninstall | enable | disable | list | status)
		# shellcheck source=/dev/null
		source "$GIT_HOOKD_ROOT/libexec/git-hookd/cli/${cmd}.sh"
		;;
	--version | -v)
		echo "git-hookd v${VERSION}"
		;;
	--help | -h | "")
		usage
		;;
	*)
		echo "Unknown command: $cmd" >&2
		usage >&2
		exit 1
		;;
esac
